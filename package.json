{
  "name": "with-tailwind",
  "private": true,
  "scripts": {
    "postinstall": "pnpm --filter @repo/db exec prisma generate",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.6.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "turbo": "^2.10.4"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.18.0"
  }
}
